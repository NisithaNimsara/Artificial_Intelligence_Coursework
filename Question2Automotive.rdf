<?xml version='1.0' encoding='UTF-8'?>
<rdf:RDF 
xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" 
xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" 
xmlns:owl="http://www.w3.org/2002/07/owl#" 
xmlns:xsd="http://www.w3.org/2001/XMLSchema#" 
xmlns:auto="http://www.example.org/automotive#">
  

  <!-- ONTOLOGY DECLARATION -->
  <owl:Ontology rdf:about="http://www.example.org/automotive#AutomotiveOntology">
    <rdfs:label>Automotive Ontology</rdfs:label>
  </owl:Ontology>

  <!-- TOP LEVEL CLASSES -->
  <owl:Class rdf:about="http://www.example.org/automotive#VehicleComponentClassification">
    <rdfs:label>VehicleComponentClassification</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://www.example.org/automotive#ManufacturingProcessManagement">
    <rdfs:label>ManufacturingProcessManagement</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://www.example.org/automotive#QualityAssuranceAndTesting">
    <rdfs:label>QualityAssuranceAndTesting</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://www.example.org/automotive#ComplianceAndRegulations">
    <rdfs:label>ComplianceAndRegulations</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://www.example.org/automotive#SecurityControlsAndMaintenancePolicies">
    <rdfs:label>SecurityControlsAndMaintenancePolicies</rdfs:label>
  </owl:Class>

  <!-- VEHICLE SUBCLASSES -->
  <owl:Class rdf:about="http://www.example.org/automotive#PowertrainComponent">
    <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#VehicleComponentClassification"/>
    <rdfs:label>PowertrainComponent</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://www.example.org/automotive#ChassisSafetyComponent">
    <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#VehicleComponentClassification"/>
    <rdfs:label>ChassisSafetyComponent</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://www.example.org/automotive#ElectricalElectronicComponent">
    <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#VehicleComponentClassification"/>
    <rdfs:label>ElectricalElectronicComponent</rdfs:label>
  </owl:Class>

  <!-- MANUFACTURING SUBCLASSES -->
  <owl:Class rdf:about="http://www.example.org/automotive#BodyManufacturingProcess">
    <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#ManufacturingProcessManagement"/>
    <rdfs:label>BodyManufacturingProcess</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://www.example.org/automotive#CoatingAndAssemblyProcess">
    <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#ManufacturingProcessManagement"/>
    <rdfs:label>CoatingAndAssemblyProcess</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://www.example.org/automotive#InspectionProcess">
    <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#ManufacturingProcessManagement"/>
    <rdfs:label>InspectionProcess</rdfs:label>
  </owl:Class>

  <!-- QUALITY SUBCLASSES -->
  <owl:Class rdf:about="http://www.example.org/automotive#QualityCoreTool">
    <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#QualityAssuranceAndTesting"/>
    <rdfs:label>QualityCoreTool</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://www.example.org/automotive#TestingAndValidationMethod">
    <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#QualityAssuranceAndTesting"/>
    <rdfs:label>TestingAndValidationMethod</rdfs:label>
  </owl:Class>

  <!-- COMPLIANCE SUBCLASSES -->
  <owl:Class rdf:about="http://www.example.org/automotive#AutomotiveStandardOrRegulation">
    <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#ComplianceAndRegulations"/>
    <rdfs:label>AutomotiveStandardOrRegulation</rdfs:label>
  </owl:Class>

  <!-- SECURITY AND MAINTENANCE SUBCLASSES -->
  <owl:Class rdf:about="http://www.example.org/automotive#MaintenancePolicy">
    <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#SecurityControlsAndMaintenancePolicies"/>
    <rdfs:label>MaintenancePolicy</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://www.example.org/automotive#SecurityControlPolicy">
    <rdfs:subClassOf rdf:resource="http://www.example.org/automotive#SecurityControlsAndMaintenancePolicies"/>
    <rdfs:label>SecurityControlPolicy</rdfs:label>
  </owl:Class>

  <!-- OBJECT PROPERTIES -->
  <owl:ObjectProperty rdf:about="http://www.example.org/automotive#hasBranch">
    <rdfs:label>hasBranch</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.example.org/automotive#manufacturedBy">
    <rdfs:domain rdf:resource="http://www.example.org/automotive#VehicleComponentClassification"/>
    <rdfs:range rdf:resource="http://www.example.org/automotive#ManufacturingProcessManagement"/>
    <rdfs:label>manufacturedBy</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.example.org/automotive#validatedBy">
    <rdfs:domain rdf:resource="http://www.example.org/automotive#VehicleComponentClassification"/>
    <rdfs:range rdf:resource="http://www.example.org/automotive#QualityAssuranceAndTesting"/>
    <rdfs:label>validatedBy</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.example.org/automotive#compliesWith">
    <rdfs:domain rdf:resource="http://www.example.org/automotive#VehicleComponentClassification"/>
    <rdfs:range rdf:resource="http://www.example.org/automotive#ComplianceAndRegulations"/>
    <rdfs:label>compliesWith</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.example.org/automotive#maintainedBy">
    <rdfs:domain rdf:resource="http://www.example.org/automotive#VehicleComponentClassification"/>
    <rdfs:range rdf:resource="http://www.example.org/automotive#SecurityControlsAndMaintenancePolicies"/>
    <rdfs:label>maintainedBy</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.example.org/automotive#protectedBy">
    <rdfs:domain rdf:resource="http://www.example.org/automotive#ElectricalElectronicComponent"/>
    <rdfs:range rdf:resource="http://www.example.org/automotive#SecurityControlPolicy"/>
    <rdfs:label>protectedBy</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.example.org/automotive#checkedBy">
    <rdfs:domain rdf:resource="http://www.example.org/automotive#BodyManufacturingProcess"/>
    <rdfs:range rdf:resource="http://www.example.org/automotive#InspectionProcess"/>
    <rdfs:label>checkedBy</rdfs:label>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.example.org/automotive#supportsComplianceWith">
    <rdfs:domain rdf:resource="http://www.example.org/automotive#TestingAndValidationMethod"/>
    <rdfs:range rdf:resource="http://www.example.org/automotive#AutomotiveStandardOrRegulation"/>
    <rdfs:label>supportsComplianceWith</rdfs:label>
  </owl:ObjectProperty>

  <!-- INDIVIDUALS: VEHICLE COMPONENTS -->
  <rdf:Description rdf:about="http://www.example.org/automotive#PetrolEngine">
    <rdf:type rdf:resource="http://www.example.org/automotive#PowertrainComponent"/>
    <rdfs:label>PetrolEngine</rdfs:label>
    <auto:manufacturedBy rdf:resource="http://www.example.org/automotive#FinalAssemblyLine"/>
    <auto:validatedBy rdf:resource="http://www.example.org/automotive#ProductionPPAP"/>
    <auto:compliesWith rdf:resource="http://www.example.org/automotive#IATF16949Standard"/>
    <auto:maintainedBy rdf:resource="http://www.example.org/automotive#OilChangeSchedule"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://www.example.org/automotive#DieselEngine">
